{
  "name": "@tonys-workbench/client",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "npm run test:unit",
    "test:unit": "ng test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:a11y": "npm run test:e2e -- --grep accessibility",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "lint:styles": "stylelint \"src/**/*.scss\"",
    "lint:styles:fix": "stylelint \"src/**/*.scss\" --fix",
    "format:check": "prettier . --check",
    "format:fix": "prettier . --write",
    "quality:architecture": "depcruise --config .dependency-cruiser.cjs src",
    "quality:dead-code": "knip",
    "check": "npm run lint && npm run lint:styles && npm run format:check && npm run test:unit && npm run quality:architecture && npm run quality:dead-code"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^21.2.14",
    "@angular/common": "^21.2.16",
    "@angular/compiler": "^21.2.16",
    "@angular/core": "^21.2.16",
    "@angular/forms": "^21.2.16",
    "@angular/material": "^21.2.14",
    "@angular/platform-browser": "^21.2.16",
    "@angular/router": "^21.2.16",
    "@fontsource/inter": "^5.2.8",
    "@ngrx/signals": "^21.1.0",
    "@tanstack/angular-query-experimental": "^5.101.0",
    "docx": "^9.7.1",
    "echarts": "^6.1.0",
    "exceljs": "^4.4.0",
    "marked": "^18.0.5",
    "material-symbols": "^0.44.12",
    "ngx-echarts": "^21.0.0",
    "ngx-markdown": "^21.3.0",
    "pdfmake": "^0.3.10",
    "prismjs": "^1.30.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.4.0",
    "@angular/build": "^21.2.14",
    "@angular/cli": "^21.2.14",
    "@angular/compiler-cli": "^21.2.16",
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "angular-eslint": "21.4.0",
    "axe-core": "^4.12.0",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "jsdom": "^28.0.0",
    "knip": "^6.16.1",
    "prettier": "^3.8.1",
    "stylelint": "^17.13.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
