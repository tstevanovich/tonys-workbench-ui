{
  "name": "@tonys-workbench/server",
  "version": "0.0.0",
  "description": "Node.js web/API server for Tony's Workbench.",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsc -p tsconfig.json",
    "check": "npm run lint && npm run typecheck && npm run test",
    "check:ci": "npm run check",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "pack": "npm pack --loglevel warn",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "http-proxy-middleware": "^4.1.1",
    "mssql": "^12.5.5",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/mssql": "^12.3.0",
    "@types/node": "^24.13.1",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
