{
  "name": "tonys-workbench",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "npm run test:unit",
    "test:unit": "ng test",
    "pretest:e2e": "npm run build",
    "test:e2e": "node tools/run-e2e.mjs",
    "test:e2e:ui": "playwright test --ui",
    "serve:e2e": "node tools/e2e-server.mjs",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "lint:styles": "stylelint \"src/**/*.scss\"",
    "lint:styles:fix": "stylelint \"src/**/*.scss\" --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "quality:architecture": "depcruise --config .dependency-cruiser.cjs src",
    "quality:dead-code": "knip",
    "security:audit": "npm audit --audit-level=moderate",
    "check": "npm run lint && npm run lint:styles && npm run format:check && npm run quality:architecture && npm run quality:dead-code",
    "check:ci": "npm run check && npm run security:audit",
    "prepare": "husky"
  },
  "private": true,
  "packageManager": "npm@11.15.0",
  "overrides": {
    "uuid": "^11.1.1"
  },
  "lint-staged": {
    "*.{ts,html,scss,json,md}": [
      "prettier --write --ignore-unknown"
    ],
    "src/**/*.scss": [
      "stylelint --fix"
    ],
    "src/**/*.{ts,html}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@angular/cdk": "^21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@ngrx/signals": "^21.1.0",
    "@tanstack/angular-query-experimental": "^5.100.13",
    "docx": "^9.6.1",
    "echarts": "^6.1.0",
    "exceljs": "^4.4.0",
    "marked": "^18.0.4",
    "material-symbols": "^0.44.9",
    "ngx-echarts": "^21.0.0",
    "ngx-markdown": "^21.3.0",
    "pdfmake": "^0.3.9",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.4.0",
    "@angular/build": "^21.2.12",
    "@angular/cli": "^21.2.12",
    "@angular/compiler-cli": "^21.2.0",
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "angular-eslint": "21.4.0",
    "axe-core": "^4.11.4",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "knip": "^6.14.2",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.1",
    "stylelint": "^17.12.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.59.2",
    "vitest": "^4.0.8"
  }
}
