{
  "name": "tonys-workbench-ui",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@11.15.0",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "overrides": {
    "uuid": "^11.1.1"
  },
  "scripts": {
    "start": "npm --workspace client run start",
    "build": "npm --workspace client run build",
    "watch": "npm --workspace client run watch",
    "test": "npm run test:unit",
    "test:unit": "npm --workspace client run test:unit",
    "test:e2e": "npm --workspace client run test:e2e",
    "test:e2e:ui": "npm --workspace client run test:e2e:ui",
    "test:a11y": "npm --workspace client run test:a11y",
    "lint": "npm --workspace client run lint",
    "lint:fix": "npm --workspace client run lint:fix",
    "lint:client:styles": "npm --workspace client run lint:styles",
    "lint:client:styles:fix": "npm --workspace client run lint:styles:fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "quality:architecture": "npm --workspace client run quality:architecture",
    "quality:dead-code": "npm --workspace client run quality:dead-code",
    "security:audit": "npm audit --audit-level=moderate",
    "check": "npm run lint && npm run lint:client:styles && npm run format:check && npm run test:unit && npm run quality:architecture && npm run quality:dead-code && npm --workspace server run check",
    "check:ci": "npm run check && npm run security:audit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,html,scss,json,md,yml,yaml}": [
      "prettier --write --ignore-unknown"
    ],
    "client/src/**/*.scss": [
      "stylelint --config client/stylelint.config.mjs --fix"
    ],
    "client/src/**/*.{ts,html}": [
      "eslint --config client/eslint.config.js --fix"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.1"
  }
}
