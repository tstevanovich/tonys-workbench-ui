{
  // For more information, visit: https://angular.dev/ai/mcp
  "servers": {
    "angular-cli": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@angular/cli", "mcp"]
    },
    "ESLint": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@eslint/mcp@latest"],
      "cwd": "${workspaceFolder}"
    },
    "vscode-diagnostics": {
      "type": "http",
      "url": "http://127.0.0.1:3846/mcp"
    }
  }
}
